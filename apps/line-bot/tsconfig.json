{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "strict": true,
    "types": ["node"],
    "paths": {
      "@saifit/db": ["../../packages/db/src/index.ts"],
      "@saifit/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["src", "test"],
  "exclude": ["dist", "node_modules"]
}
