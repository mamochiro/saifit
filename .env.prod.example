# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=saifit
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=saifit

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── Better Auth ──────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change_me_32char_random_secret
